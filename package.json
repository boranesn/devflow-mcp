{
  "name": "devflow-mcp",
  "version": "1.0.0",
  "description": "A production-ready MCP server for developer tooling — PR analysis, code review, changelog generation, dependency auditing, and more.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devflow-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@octokit/plugin-throttling": "^9.3.2",
    "@octokit/rest": "^21.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^3.1.1",
    "msw": "^2.7.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
